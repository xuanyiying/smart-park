# Build stage
FROM golang:1.22-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git make protobuf

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /app/billing-svc ./cmd/billing-svc

# Final stage
FROM alpine:latest

WORKDIR /app

RUN apk --no-cache add ca-certificates tzdata

COPY --from=builder /app/billing-svc .
COPY configs/billing.yaml /app/configs/billing.yaml

EXPOSE 8002

CMD ["./billing-svc"]
